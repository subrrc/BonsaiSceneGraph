# spaceship_lowpoly.obj
mtllib spaceship_lowpoly.mtl
o LowPolyShip

# Simple low-poly spaceship:
# - plastic: main hull + wings
# - brass: cockpit canopy + engine bells
# - rubber: engine nozzle rings

# ----------------------
# Vertices
# ----------------------

# Hull (a stretched diamond prism)
v  0.00  0.00  1.20   # 1 nose tip
v -0.35  0.00  0.40   # 2 left mid
v  0.35  0.00  0.40   # 3 right mid
v  0.00  0.18  0.35   # 4 top mid
v  0.00 -0.18  0.35   # 5 bottom mid
v  0.00  0.00 -0.90   # 6 tail tip

# Hull “thickness” corners (rear-ish)
v -0.22  0.10 -0.20   # 7 left-top
v  0.22  0.10 -0.20   # 8 right-top
v  0.22 -0.10 -0.20   # 9 right-bottom
v -0.22 -0.10 -0.20   #10 left-bottom

# Wings (flat triangles)
v -0.95  0.00  0.10   #11 left wing tip
v -0.35  0.00  0.15   #12 left wing root
v  0.95  0.00  0.10   #13 right wing tip
v  0.35  0.00  0.15   #14 right wing root

# Vertical tail fin (triangle)
v  0.00  0.55 -0.55   #15 fin top
v  0.00  0.12 -0.35   #16 fin base front
v  0.00  0.12 -0.75   #17 fin base back

# Cockpit (small wedge)
v  0.00  0.16  0.65   #18 cockpit top
v -0.12  0.06  0.62   #19 cockpit left
v  0.12  0.06  0.62   #20 cockpit right
v  0.00  0.02  0.48   #21 cockpit back

# Engine bells (two simple pyramids)
# Left engine
v -0.18  0.00 -0.70   #22 left engine center
v -0.28  0.06 -0.58   #23 left engine top
v -0.28 -0.06 -0.58   #24 left engine bottom
v -0.08  0.06 -0.58   #25 left engine inner top
v -0.08 -0.06 -0.58   #26 left engine inner bottom

# Right engine
v  0.18  0.00 -0.70   #27 right engine center
v  0.08  0.06 -0.58   #28 right engine inner top
v  0.08 -0.06 -0.58   #29 right engine inner bottom
v  0.28  0.06 -0.58   #30 right engine top
v  0.28 -0.06 -0.58   #31 right engine bottom

# Nozzle rings (rubber) - simple quad-ish around each engine mouth (two triangles per ring)
# Left ring
v -0.30  0.08 -0.60   #32
v -0.30 -0.08 -0.60   #33
v -0.06 -0.08 -0.60   #34
v -0.06  0.08 -0.60   #35

# Right ring
v  0.06  0.08 -0.60   #36
v  0.06 -0.08 -0.60   #37
v  0.30 -0.08 -0.60   #38
v  0.30  0.08 -0.60   #39

# ----------------------
# Faces
# ----------------------

# HULL (plastic)
usemtl plastic
g hull

# Nose to mid (4 faces)
f 1 3 4
f 1 4 2
f 1 2 5
f 1 5 3

# Mid to tail thickness (connect mid points to rear-ish corners)
f 2 4 7
f 4 3 8
f 3 5 9
f 5 2 10

# Rear-ish box to tail tip
f 7 8 6
f 8 9 6
f 9 10 6
f 10 7 6

# Close the rear-ish “ring” (optional sealing)
f 7 10 9
f 7 9 8

# WINGS (plastic)
g wings
f 12 11 2
f 14 3 13

# Tail fin (plastic)
g fin
f 16 15 17

# COCKPIT (brass)
usemtl brass
g cockpit
f 18 20 19
f 19 20 21
f 20 18 21
f 18 19 21

# ENGINES (brass)
usemtl brass
g engines

# Left engine pyramid-ish (center back to rim)
f 22 23 25
f 22 25 26
f 22 26 24
f 22 24 23

# Right engine
f 27 28 30
f 27 30 31
f 27 31 29
f 27 29 28

# NOZZLE RINGS (rubber)
usemtl rubber
g nozzles

# Left ring (two triangles)
f 32 33 34
f 32 34 35

# Right ring (two triangles)
f 36 37 38
f 36 38 39