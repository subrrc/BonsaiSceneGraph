# spaceship_detailed.obj
mtllib spaceship_detailed.mtl
o DetailedShip

# A more detailed “low-poly” spaceship:
# - segmented hull (top/bottom/left/right panels)
# - dual wings with winglets
# - cockpit canopy
# - twin engines + nozzle rings
# - small dorsal fin + side intakes

# ----------------------
# Vertices
# ----------------------

# Nose section (segmented)
v  0.00  0.00  1.70   # 1 nose tip
v  0.00  0.14  1.35   # 2 nose top
v  0.00 -0.14  1.35   # 3 nose bottom
v -0.16  0.00  1.35   # 4 nose left
v  0.16  0.00  1.35   # 5 nose right

# Front ring
v  0.00  0.20  0.95   # 6 front top
v  0.00 -0.20  0.95   # 7 front bottom
v -0.24  0.00  0.95   # 8 front left
v  0.24  0.00  0.95   # 9 front right

# Mid ring (slightly wider)
v  0.00  0.24  0.30   #10 mid top
v  0.00 -0.24  0.30   #11 mid bottom
v -0.30  0.00  0.30   #12 mid left
v  0.30  0.00  0.30   #13 mid right

# Rear ring (thicker, near engines)
v  0.00  0.22 -0.35   #14 rear top
v  0.00 -0.22 -0.35   #15 rear bottom
v -0.28  0.00 -0.35   #16 rear left
v  0.28  0.00 -0.35   #17 rear right

# Tail tip
v  0.00  0.00 -1.20   #18 tail tip

# Additional “corner” verts to add facets around mid/rear (gives more detail)
v -0.18  0.14  0.30   #19 mid left-top
v  0.18  0.14  0.30   #20 mid right-top
v  0.18 -0.14  0.30   #21 mid right-bottom
v -0.18 -0.14  0.30   #22 mid left-bottom

v -0.16  0.12 -0.35   #23 rear left-top
v  0.16  0.12 -0.35   #24 rear right-top
v  0.16 -0.12 -0.35   #25 rear right-bottom
v -0.16 -0.12 -0.35   #26 rear left-bottom

# Cockpit canopy (brass)
v  0.00  0.24  0.85   #27 canopy top front
v -0.14  0.10  0.82   #28 canopy left front
v  0.14  0.10  0.82   #29 canopy right front
v  0.00  0.10  0.55   #30 canopy back

# Dorsal fin (plastic)
v  0.00  0.55 -0.55   #31 fin top
v  0.00  0.20 -0.35   #32 fin base front
v  0.00  0.20 -0.80   #33 fin base back

# Wings (plastic) - left
v -0.40  0.00  0.25   #34 left wing root front
v -0.60  0.00 -0.10  #35 left wing root mid
v -1.10  0.00  0.05  #36 left wing tip
v -0.85  0.00 -0.55  #37 left wing aft tip

# Wings (plastic) - right
v  0.40  0.00  0.25   #38 right wing root front
v  0.60  0.00 -0.10  #39 right wing root mid
v  1.10  0.00  0.05  #40 right wing tip
v  0.85  0.00 -0.55  #41 right wing aft tip

# Winglets (plastic) - small upward triangles
v -1.05  0.18  0.02  #42 left winglet top
v  1.05  0.18  0.02  #43 right winglet top

# Side intakes (brass) - left and right small boxes (triangulated)
# Left intake
v -0.36  0.06  0.10  #44
v -0.36 -0.06  0.10 #45
v -0.50 -0.06 -0.05 #46
v -0.50  0.06 -0.05 #47
# Right intake
v  0.36  0.06  0.10  #48
v  0.36 -0.06  0.10 #49
v  0.50 -0.06 -0.05 #50
v  0.50  0.06 -0.05 #51

# Engines (brass) - two bells (each a small pyramid-ish frustum)
# Left engine mouth rectangle (near rear ring)
v -0.35  0.10 -0.60  #52 left outer top
v -0.35 -0.10 -0.60 #53 left outer bottom
v -0.15 -0.10 -0.60 #54 left inner bottom
v -0.15  0.10 -0.60 #55 left inner top
v -0.25  0.00 -0.95 #56 left engine center (back)

# Right engine
v  0.15  0.10 -0.60  #57 right inner top
v  0.15 -0.10 -0.60 #58 right inner bottom
v  0.35 -0.10 -0.60 #59 right outer bottom
v  0.35  0.10 -0.60  #60 right outer top
v  0.25  0.00 -0.95  #61 right engine center (back)

# Nozzle rings (rubber) - two quads (2 tris each)
# Left ring (slightly larger than engine mouth)
v -0.38  0.12 -0.60  #62
v -0.38 -0.12 -0.60 #63
v -0.12 -0.12 -0.60 #64
v -0.12  0.12 -0.60 #65

# Right ring
v  0.12  0.12 -0.60  #66
v  0.12 -0.12 -0.60 #67
v  0.38 -0.12 -0.60 #68
v  0.38  0.12 -0.60  #69

# ----------------------
# Faces
# ----------------------

